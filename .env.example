# ──────────────────────────────────────────────
# Personal OS — Environment Variables
# Copy this file to .env.local and fill in values
# ──────────────────────────────────────────────

# Required — Notion Integration Secret
# Get from: https://www.notion.so/profile/integrations
NOTION_TOKEN=secret_your_integration_token_here

# Required — Notion Tasks Database ID
# Get from the DB page URL in your browser
NOTION_TASKS_DB=your_database_id_here

# Optional — Area IDs for color-coded workstreams
# Only needed if you use the "Areas" relation in your DB
# Leave empty to show all tasks without area filtering
NOTION_STS_AREA_ID=
NOTION_DAISI_AREA_ID=
NOTION_DIGITAL_PRODUCT_AREA_ID=
